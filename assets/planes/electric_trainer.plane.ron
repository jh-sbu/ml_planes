// Electric Trainer — battery-electric demonstrator PlaneConfig.
// Smaller, lighter airframe than the generic jet. The key difference is the
// powerplant: charge depletes with use but the airframe mass is CONSTANT (the
// battery mass is already included in `mass`).
(
    // --- Geometry ---
    wing_area: 12.0,        // S  [m²]
    mean_chord: 1.5,        // c̄  [m]
    wing_span: 8.0,         // b  [m]

    // --- Mass / Inertia ---
    mass: 1200.0,           // [kg] total, constant (battery mass baked in — charge adds none)
    inertia: (1800.0, 6000.0, 6800.0), // Ixx, Iyy, Izz [kg·m²]

    // --- Longitudinal Aerodynamic Coefficients ---
    cl0: 0.1,
    cl_alpha: 4.5,
    cl_delta_e: 0.4,
    cl_max: 1.4,

    cd0: 0.022,
    cd_induced: 0.05,

    cm0: -0.02,
    cm_alpha: 0.6,
    cm_q: -14.0,
    cm_delta_e: -1.2,

    // --- Lateral-Directional Coefficients ---
    cl_beta: 0.08,          // dihedral — sign flipped vs NED (positive roll torque = +Y wing UP here)
    cl_p: -0.45,
    cl_r: -0.12,            // roll due to yaw rate — sign flipped vs NED
    cl_delta_a: 0.18,

    cn_beta: 0.10,
    cn_r: -0.12,
    cn_delta_r: -0.10,

    // --- Engine ---
    thrust_max: 8000.0,     // [N] at throttle = 1.0 (electric motor)

    // --- Powerplant (consumable) ---
    // Battery-electric: charge depletes but mass stays constant. capacity = full charge
    // [kWh]; consumption = charge drawn per unit thrust-second [kWh/(N·s)]. At full thrust
    // this drains 0.1 kWh/s (~20 min endurance from a 120 kWh pack).
    powerplant: Electric(capacity: 120.0, consumption: 1.25e-5),

    // --- Control Limits ---
    aileron_limit: 0.4363,  // [rad] ≈ 25°
    elevator_limit: 0.3491, // [rad] ≈ 20°
    rudder_limit: 0.2618,   // [rad] ≈ 15°
)
