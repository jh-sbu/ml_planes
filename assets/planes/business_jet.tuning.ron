// PID gains for business_jet.plane.ron.
// level_hold "normal" — /tune-validated 2026-06-15, 2 rounds. Passes all 5 envelope
// scenarios (200/80, 500/100, 1000/130, 2000/110, 300/70) with ΔAlt ≤ 1.3 m, ΔSpd ≤ 0.9 m/s.
// vs starter: pitch_kd 0.764→1.146 (killed a ~1.4 s short-period limit cycle),
// spd_ki 0.129→0.258 (removed ~3 m/s steady offset at the high/fast point).
// orbit / heading_hold remain physics-scaled starters — not yet /tune-validated.
PlaneTuning(
    level_hold: {
        "normal": LevelHoldTuning(
            alt_kp: 0.0206,
            alt_ki: 0.302,
            alt_kd: 0.192,
            pitch_kp: 0.910,
            pitch_kd: 1.146,
            spd_kp: 0.0215,
            spd_ki: 0.258,
            throttle_ff_gain: 0.3,
        ),
    },
    orbit: {
        "normal": OrbitTuning(
            radial_kp: 0.002,
            radial_kd: 0.01,
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0137,
                alt_ki: 0.165,
                alt_kd: 0.055,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.0215,
                spd_ki: 0.129,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
    heading_hold: {
        "normal": HeadingHoldTuning(
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0137,
                alt_ki: 0.165,
                alt_kd: 0.055,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.0215,
                spd_ki: 0.129,
                throttle_ff_gain: 0.7,
            ),
