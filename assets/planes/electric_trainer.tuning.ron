// Physics-scaled STARTER PID gains for electric_trainer.plane.ron — NOT yet /tune-validated.
// Derived from generic_jet.tuning.ron "normal" profiles scaled by the electric trainer's
// cruise physics (tune skill Phase-1 ratios): altitude gains ∝ 1/V_c (V_c≈70 m/s ⇒
// ×1.87), airspeed gains ∝ T_c/V_c (×2.60). Pitch inner loop and feedforward kept at
// generic values (nondimensionally similar; same cm_δe / elevator authority).
// Mass is constant (battery), so no fuel-burn lightening to compensate for.
// Run `/tune assets/planes/electric_trainer.plane.ron <controller>` to refine across the envelope.
PlaneTuning(
    level_hold: {
        "normal": LevelHoldTuning(
            alt_kp: 0.0281,
            alt_ki: 0.412,
            alt_kd: 0.262,
            pitch_kp: 0.910,
            pitch_kd: 0.764,
            spd_kp: 0.026,
            spd_ki: 0.156,
            throttle_ff_gain: 0.3,
        ),
    },
    orbit: {
        "normal": OrbitTuning(
            radial_kp: 0.002,
            radial_kd: 0.01,
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0187,
                alt_ki: 0.224,
                alt_kd: 0.075,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.026,
                spd_ki: 0.156,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
    heading_hold: {
        "normal": HeadingHoldTuning(
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0187,
                alt_ki: 0.224,
                alt_kd: 0.075,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.026,
                spd_ki: 0.156,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
)
