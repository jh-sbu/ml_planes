// PID gains for cargo_jet.plane.ron.
// level_hold "normal" is /tune-validated (2026-06-23) across the flight envelope.
// orbit and heading_hold remain physics-scaled STARTER gains — NOT yet /tune-validated;
// run `/tune assets/planes/cargo_jet.plane.ron <controller>` to refine them.
PlaneTuning(
    level_hold: {
        // Profile "normal" — level-hold tune 2026-06-23, 2 rounds.
        // Validated across 5 envelope points (500/120, 1000/160, 2000/190,
        // 3000/170, 300/110); worst ΔAlt ≤ 3.6 m, worst ΔSpd ≤ 0.26 m/s.
        // Note: ki sized for the integral-clamp architecture (ki·clamp ≥ trim),
        // and a stiff+damped inner pitch loop (2.0/8.0) to kill the phugoid limit
        // cycle of the 218 t loaded heavy jet.
        "normal": LevelHoldTuning(
            alt_kp: 0.015,
            alt_ki: 0.22,
            alt_kd: 0.20,
            pitch_kp: 2.0,
            pitch_kd: 8.0,
            spd_kp: 0.04,
            spd_ki: 0.30,
            throttle_ff_gain: 0.3,
        ),
    },
    orbit: {
        "normal": OrbitTuning(
            radial_kp: 0.002,
            radial_kd: 0.01,
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0077,
                alt_ki: 0.092,
                alt_kd: 0.031,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.022,
                spd_ki: 0.132,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
    heading_hold: {
        "normal": HeadingHoldTuning(
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0077,
                alt_ki: 0.092,
                alt_kd: 0.031,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.022,
                spd_ki: 0.132,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
)
