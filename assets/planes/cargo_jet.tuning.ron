// PID gains for cargo_jet.plane.ron.
// level_hold "normal" is /tune-validated (2026-06-19) across the flight envelope.
// orbit and heading_hold remain physics-scaled STARTER gains — NOT yet /tune-validated;
// run `/tune assets/planes/cargo_jet.plane.ron <controller>` to refine them.
PlaneTuning(
    level_hold: {
        // Profile "normal" — level-hold tune 2026-06-19, ~5 rounds.
        // Validated across 5 envelope points (200/120, 1000/160, 3000/190,
        // 2000/170, 500/130); worst ΔAlt ≤ 4.7 m, worst ΔSpd ≤ 0.95 m/s.
        // Note: ki sized for the integral-clamp architecture (ki·clamp ≥ trim),
        // and a stiff+damped inner pitch loop (1.5/2.5) to kill the limit cycle.
        "normal": LevelHoldTuning(
            alt_kp: 0.01,
            alt_ki: 0.28,
            alt_kd: 0.15,
            pitch_kp: 1.5,
            pitch_kd: 2.5,
            spd_kp: 0.02,
            spd_ki: 0.42,
            throttle_ff_gain: 0.7,
        ),
    },
    orbit: {
        "normal": OrbitTuning(
            radial_kp: 0.002,
            radial_kd: 0.01,
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0077,
                alt_ki: 0.092,
                alt_kd: 0.031,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.022,
                spd_ki: 0.132,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
    heading_hold: {
        "normal": HeadingHoldTuning(
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0077,
                alt_ki: 0.092,
                alt_kd: 0.031,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.022,
                spd_ki: 0.132,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
)
