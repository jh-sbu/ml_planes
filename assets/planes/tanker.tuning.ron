// Physics-scaled STARTER gains for orbit/heading_hold — NOT yet /tune-validated.
// Run `/tune assets/planes/tanker.plane.ron <controller>` to refine those across the envelope.
//
// level_hold."normal" — /tune-validated 2026-06-18 (passes all 5 envelope scenarios,
// 200m/80–2000m/130 m·s⁻¹). NOTE: observe_state flies the DRY 45 t airframe (it spawns
// mass=cfg.mass with infinite fuel), so these are tuned for 45 t — the live sim spawns the
// loaded ~135 t jet, which (being even more sluggish in pitch) may want still more pitch_kd.
// The tanker's huge pitch inertia gives a lightly-damped phugoid that locks into a
// ±22 m limit cycle (pitch_target clamp → bang-bang) under generic-style gains; the fix was
// heavy inner-loop pitch-rate damping (pitch_kd 0.76→8.0) plus a small alt_kd bump.
PlaneTuning(
    level_hold: {
        "normal": LevelHoldTuning(
            alt_kp: 0.015,
            alt_ki: 0.22,
            alt_kd: 0.20,
            pitch_kp: 2.0,
            pitch_kd: 8.0,
            spd_kp: 0.03,
            spd_ki: 0.15,
            throttle_ff_gain: 0.3,
        ),
    },
    orbit: {
        "normal": OrbitTuning(
            radial_kp: 0.002,
            radial_kd: 0.01,
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0078,
                alt_ki: 0.094,
                alt_kd: 0.031,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.0247,
                spd_ki: 0.148,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
    heading_hold: {
        "normal": HeadingHoldTuning(
            heading_kp: 0.7,
            heading_kd: 0.1,
            inner: LevelHoldTuning(
                alt_kp: 0.0078,
                alt_ki: 0.094,
                alt_kd: 0.031,
                pitch_kp: 1.000,
                pitch_kd: 0.500,
                spd_kp: 0.0247,
                spd_ki: 0.148,
                throttle_ff_gain: 0.7,
            ),
        ),
    },
)
