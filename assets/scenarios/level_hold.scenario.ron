// Single-plane level-hold envelope check.
//
// Run: cargo run --example observe_state --no-default-features -- \
//        --scenario assets/scenarios/level_hold.scenario.ron --steps 3840 --interval 64
//
// Optional fields (omit for defaults): config (embedded generic_jet),
// velocity (DEFAULT_SPEED along heading), heading_deg (0 = +X),
// angular_velocity (zero), and LevelHold `tuning` (default gains).
(
    steps: 3840,
    interval: 64,
    planes: [
        (
            name: "p",
            position: (0.0, 500.0, 0.0),
            controller: LevelHold(
                altitude: 500.0,
                airspeed: 100.0,
            ),
        ),
    ],
)
